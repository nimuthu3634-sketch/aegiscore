# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=AegisCore API
# development | production
APP_ENV=development
# URL prefix for all API routes
API_PREFIX=/api/v1

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Docker Compose default: postgresql+psycopg://aegiscore:aegiscore@postgres:5432/aegiscore
# Local dev default: postgresql+psycopg://aegiscore:aegiscore@localhost:5432/aegiscore
DATABASE_URL=postgresql+psycopg://aegiscore:aegiscore@localhost:5432/aegiscore

# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis connection string. Used for rate limiting and the RQ job queue.
REDIS_URL=redis://localhost:6379/0

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# REQUIRED in production: replace with a strong random secret (e.g. openssl rand -hex 32)
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
# Token lifetime in minutes (default 60)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── ML ────────────────────────────────────────────────────────────────────────
# Version prefix stamped on trained model artifacts (e.g. 2026.03)
MODEL_VERSION=2026.03

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Must be exact origins — wildcards are blocked when credentials are enabled.
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Rate limiting (optional overrides) ───────────────────────────────────────
# LOGIN_RATE_LIMIT_ATTEMPTS=5
# LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
# WRITE_RATE_LIMIT_ATTEMPTS=20
# WRITE_RATE_LIMIT_WINDOW_SECONDS=60

# ── Cookie security (optional overrides) ─────────────────────────────────────
# AUTH_COOKIE_SECURE=false       # set true in production (HTTPS only)
# AUTH_COOKIE_SAMESITE=lax       # lax | strict | none
# AUTH_COOKIE_DOMAIN=            # set to your domain in production
